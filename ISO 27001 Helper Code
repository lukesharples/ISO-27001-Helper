def normalise_control(user_input):
    user_input = user_input.strip().upper()   # remove spaces, standardise case
    user_input = user_input.replace('A.', '') # remove 'A.'
    user_input = user_input.replace('A', '')  # remove 'A' if no dot
    return user_input

